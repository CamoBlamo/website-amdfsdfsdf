# Runtime
NODE_ENV=production
PORT=3000

# Security (required in production)
SESSION_TOKEN_SECRET=replace-with-a-long-random-secret
# Optional aliases used by the app if SESSION_TOKEN_SECRET is absent:
# AUTH_SECRET=replace-with-a-long-random-secret
# JWT_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public&sslmode=require

# OAuth (Google only)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public URL
SITE_URL=https://devdock.cc

# Optional app webhook settings
APPLICATION_WEBHOOK_URL=https://your-webhook-service/your-path
