{
  "buildCommand": "npm ci",
  "headers": [
    {
      "source": "/(.*)\\.(js)$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css)$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html)$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth-google",
      "destination": "/api/oauth?provider=google"
    },
    {
      "source": "/api/auth-discord",
      "destination": "/api/oauth?provider=discord"
    },
    {
      "source": "/api/auth-google-callback",
      "destination": "/api/oauth?provider=google&phase=callback"
    },
    {
      "source": "/api/auth-discord-callback",
      "destination": "/api/oauth?provider=discord&phase=callback"
    },
    {
      "source": "/api/announcements/latest",
      "destination": "/api/announcements?mode=latest"
    },
    {
      "source": "/api/announcements/:id/seen",
      "destination": "/api/announcements?mode=seen&id=:id"
    }
  ]
}
